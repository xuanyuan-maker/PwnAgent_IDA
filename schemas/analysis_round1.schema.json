{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Round1Analysis",
  "type": "object",
  "required": ["suspicious_functions", "hypotheses", "evidence_gaps", "next_evidence_requests"],
  "properties": {
    "analysis_order": {
      "type": "array",
      "items": {"type": "string"}
    },
    "function_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "suspicious", "reason"],
        "properties": {
          "name": {"type": "string"},
          "role": {"type": "string"},
          "suspicious": {"type": "string"},
          "reason": {"type": "string"},
          "rename_suggestion": {"type": "string"}
        }
      }
    },
    "semantic_renames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["original_name", "suggested_name", "reason"],
        "properties": {
          "original_name": {"type": "string"},
          "suggested_name": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "suspicious_functions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "reason"],
        "properties": {
          "name": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_gaps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_evidence_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "target"],
        "properties": {
          "tool": {"type": "string"},
          "target": {"type": "string"}
        }
      }
    }
  }
}
